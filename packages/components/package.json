{
  "name": "@swy/components",
  "version": "0.0.1",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./style.css": "./dist/style.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "build:js": "vite build",
    "build:dts": "vue-tsc -p tsconfig.build.json",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "element-plus": "^2.14.1"
  },
  "devDependencies": {
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8",
    "vue": "^3.5.34"
  }
}
